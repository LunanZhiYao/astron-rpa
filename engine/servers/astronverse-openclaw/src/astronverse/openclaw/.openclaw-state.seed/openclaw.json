{
  "gateway": {
    "mode": "local",
    "port": 19878,
    "bind": "loopback"
  },
  "logging": {
    "level": "info",
    "consoleLevel": "info",
    "consoleStyle": "pretty",
    "redactSensitive": "tools",
    "file": "~/.openclaw-state/logs/openclaw.log"
  },
  "auth": {
    "profiles": {
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": ""
      },
      "models": {
      },
      "workspace": "~/.openclaw-state/workspace",
      "compaction": {
        "mode": "safeguard"
      }
    }
  },
  "tools": {
    "profile": "full"
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "boot-md": {
          "enabled": true
        }
      }
    }
  }
}
